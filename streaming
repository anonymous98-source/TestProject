🧭 Step 3: Sidebar with Icons + Selection

Update menu item:

private JButton createMenuItem(String text, String icon) {
    JButton btn = new JButton(text, IconUtil.get(icon));

    btn.setHorizontalAlignment(SwingConstants.LEFT);
    btn.setIconTextGap(10);
    btn.setFocusPainted(false);
    btn.setBorder(BorderFactory.createEmptyBorder(12, 20, 12, 10));
    btn.setFont(new Font("Segoe UI", Font.PLAIN, 14));
    btn.setForeground(Theme.TEXT_SECONDARY);
    btn.setBackground(Theme.SIDEBAR);
    btn.setCursor(new Cursor(Cursor.HAND_CURSOR));

    btn.addActionListener(e -> {
        switchPanel(text);
        highlightSelected(btn);
    });

    btn.addMouseListener(new java.awt.event.MouseAdapter() {
        public void mouseEntered(java.awt.event.MouseEvent evt) {
            if (!btn.getBackground().equals(Theme.ACCENT)) {
                btn.setBackground(Theme.HOVER);
            }
        }

        public void mouseExited(java.awt.event.MouseEvent evt) {
            if (!btn.getBackground().equals(Theme.ACCENT)) {
                btn.setBackground(Theme.SIDEBAR);
            }
        }
    });

    return btn;
}


