public void update(Snippet snippet) {
    String sql = "UPDATE snippet SET title=?, code=? WHERE id=?";

    try (Connection conn = DBConnection.getConnection();
         PreparedStatement ps = conn.prepareStatement(sql)) {

        ps.setString(1, snippet.getTitle());
        ps.setString(2, snippet.getCode());
        ps.setInt(3, snippet.getId());
        ps.executeUpdate();

    } catch (Exception e) {
        e.printStackTrace();
    }
}

public List<Snippet> search(String keyword) {
    List<Snippet> list = new ArrayList<>();
    String sql = "SELECT * FROM snippet WHERE LOWER(title) LIKE ?";

    try (Connection conn = DBConnection.getConnection();
         PreparedStatement ps = conn.prepareStatement(sql)) {

        ps.setString(1, "%" + keyword.toLowerCase() + "%");
        ResultSet rs = ps.executeQuery();

        while (rs.next()) {
            list.add(new Snippet(
                    rs.getInt("id"),
                    rs.getString("title"),
                    rs.getString("code")
            ));
        }

    } catch (Exception e) {
        e.printStackTrace();
    }

    return list;
}


