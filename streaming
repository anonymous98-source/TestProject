package com.devworkbench.util;

import java.awt.*;

public class Theme {

    public static final Color BACKGROUND = new Color(24, 26, 31);
    public static final Color SIDEBAR = new Color(20, 22, 26);
    public static final Color CARD = new Color(32, 34, 40);

    public static final Color ACCENT = new Color(130, 90, 255); // 🔥 PURPLE
    public static final Color HOVER = new Color(45, 48, 54);

    public static final Color TEXT_PRIMARY = new Color(220, 220, 220);
    public static final Color TEXT_SECONDARY = new Color(150, 150, 150);

}


