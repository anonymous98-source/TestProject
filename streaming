Based on your project's controller test pattern (@WebMvcTest, @MockitoBean, @WithMockOflUser, MockMvc), here's a complete class with the 3 scenarios:

package com.cardinalhealth.advship.preferences.api.controller;

import com.cardinalhealth.advship.preferences.api.dto.response.FedexSubscriptionResponse;
import com.cardinalhealth.advship.preferences.api.service.FedexSubscriptionService;
import org.junit.jupiter.api.Test;
import org.mockito.Mockito;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.http.MediaType;
import org.springframework.security.test.web.servlet.request.SecurityMockMvcRequestPostProcessors;
import org.springframework.test.context.bean.override.mockito.MockitoBean;
import org.springframework.test.web.servlet.MockMvc;

import java.util.UUID;

import static org.springframework.security.test.web.servlet.request.SecurityMockMvcRequestPostProcessors.csrf;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

@WebMvcTest(FedexSubscriptionController.class)
class FedexSubscriptionControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockitoBean
    private FedexSubscriptionService fedexSubscriptionService;

    @Test
    @WithMockOflUser(role = "ADVSHIP_ADMIN")
    void testGetFedexSubscription_ValidRequest() throws Exception {

        UUID customerId = UUID.randomUUID();
        UUID registrationId = UUID.randomUUID();
        UUID subscriptionId = UUID.randomUUID();
        String accountNumber = "123456";

        FedexSubscriptionResponse response =
                FedexSubscriptionResponse.builder()
                        .registrationId(registrationId)
                        .subscriptionId(subscriptionId)
                        .accountNumber(accountNumber)
                        .build();

        Mockito.when(
                fedexSubscriptionService.getFedexSubscription(
                        customerId,
                        accountNumber))
                .thenReturn(response);

        mockMvc.perform(
                        get("/v1/api/fedex/subscription")
                                .contentType(MediaType.APPLICATION_JSON)
                                .with(csrf())
                                .header("Authorization", "dummy-token")
                                .param("customerId", customerId.toString())
                                .param("accountNumber", accountNumber))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.registrationId")
                        .value(registrationId.toString()))
                .andExpect(jsonPath("$.subscriptionId")
                        .value(subscriptionId.toString()))
                .andExpect(jsonPath("$.accountNumber")
                        .value(accountNumber));
    }

    @Test
    @WithMockOflUser(role = "ADVSHIP_ADMIN")
    void testGetFedexSubscription_NoDataFound() throws Exception {

        UUID customerId = UUID.randomUUID();
        String accountNumber = "123456";

        Mockito.when(
                fedexSubscriptionService.getFedexSubscription(
                        customerId,
                        accountNumber))
                .thenReturn(null);

        mockMvc.perform(
                        get("/v1/api/fedex/subscription")
                                .contentType(MediaType.APPLICATION_JSON)
                                .with(csrf())
                                .header("Authorization", "dummy-token")
                                .param("customerId", customerId.toString())
                                .param("accountNumber", accountNumber))
                .andExpect(status().isOk());
    }

    @Test
    @WithMockOflUser(role = "ADVSHIP_ADMIN")
    void testGetFedexSubscription_InvalidCustomerId() throws Exception {

        String accountNumber = "123456";

        mockMvc.perform(
                        get("/v1/api/fedex/subscription")
                                .contentType(MediaType.APPLICATION_JSON)
                                .with(csrf())
                                .header("Authorization", "dummy-token")
                                .param("customerId", "invalid-uuid")
                                .param("accountNumber", accountNumber))
                .andExpect(status().isBadRequest());
    }
}

