package com.devworkbench.ui.snippet;

import com.devworkbench.model.Snippet;
import com.devworkbench.service.SnippetService;
import org.fife.ui.rsyntaxtextarea.RSyntaxTextArea;
import org.fife.ui.rsyntaxtextarea.SyntaxConstants;
import org.fife.ui.rtextarea.RTextScrollPane;

import javax.swing.*;
import javax.swing.event.ListSelectionEvent;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.util.List;

public class SnippetPanel extends JPanel {

    private JTextField titleField;
    private JTextField searchField;
    private RSyntaxTextArea codeArea;
    private JTable table;
    private DefaultTableModel tableModel;
    private JComboBox<String> languageBox;

    private final SnippetService service = new SnippetService();
    private int selectedId = -1;

    public SnippetPanel() {
        setLayout(new BorderLayout(10, 10));
        setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        add(createToolbar(), BorderLayout.NORTH);
        add(createMainSplit(), BorderLayout.CENTER);

        loadData();
    }

    // 🔝 Toolbar (Top Bar)
    private JPanel createToolbar() {
        JPanel panel = new JPanel(new BorderLayout(10, 10));

        // LEFT → Buttons
        JToolBar toolBar = new JToolBar();
        toolBar.setFloatable(false);

        JButton newBtn = new JButton("New");
        JButton saveBtn = new JButton("Save");
        JButton updateBtn = new JButton("Update");
        JButton deleteBtn = new JButton("Delete");
        JButton copyBtn = new JButton("Copy");

        newBtn.addActionListener(e -> clearForm());
        saveBtn.addActionListener(e -> saveSnippet());
        updateBtn.addActionListener(e -> updateSnippet());
        deleteBtn.addActionListener(e -> deleteSnippet());
        copyBtn.addActionListener(e -> {
            codeArea.selectAll();
            codeArea.copy();
        });

        toolBar.add(newBtn);
        toolBar.add(saveBtn);
        toolBar.add(updateBtn);
        toolBar.add(deleteBtn);
        toolBar.addSeparator();
        toolBar.add(copyBtn);

        // RIGHT → Search
        searchField = new JTextField(20);
        searchField.setToolTipText("Search snippets...");
        JButton searchBtn = new JButton("Search");

        searchBtn.addActionListener(e -> search());

        JPanel searchPanel = new JPanel(new BorderLayout(5, 5));
        searchPanel.add(searchField, BorderLayout.CENTER);
        searchPanel.add(searchBtn, BorderLayout.EAST);

        panel.add(toolBar, BorderLayout.WEST);
        panel.add(searchPanel, BorderLayout.EAST);

        return panel;
    }

    // 🧩 Main Split Layout
    private JSplitPane createMainSplit() {

        // LEFT SIDE → Editor Section
        JPanel editorPanel = new JPanel(new BorderLayout(8, 8));

        // 🔥 Title + Language Row
        JPanel titleRow = new JPanel(new BorderLayout(10, 5));

        titleField = new JTextField();
        titleField.setPreferredSize(new Dimension(0, 35)); // FIX HEIGHT

        languageBox = new JComboBox<>(new String[]{"Java", "SQL", "JSON", "XML"});
        languageBox.setPreferredSize(new Dimension(120, 35));

        titleRow.add(titleField, BorderLayout.CENTER);
        titleRow.add(languageBox, BorderLayout.EAST);

        // 🔥 Code Editor (BIG AREA)
        codeArea = new RSyntaxTextArea(20, 60);
        codeArea.setSyntaxEditingStyle(SyntaxConstants.SYNTAX_STYLE_JAVA);
        codeArea.setCodeFoldingEnabled(true);
        codeArea.setAntiAliasingEnabled(true);
        codeArea.setFont(new Font("Consolas", Font.PLAIN, 14));

        // Dark theme editor
        codeArea.setBackground(new Color(30, 30, 30));
        codeArea.setForeground(new Color(220, 220, 220));
        codeArea.setCaretColor(Color.WHITE);
        codeArea.setCurrentLineHighlightColor(new Color(50, 50, 50));

        RTextScrollPane scrollPane = new RTextScrollPane(codeArea);
        scrollPane.setFoldIndicatorEnabled(true);

        editorPanel.add(titleRow, BorderLayout.NORTH);
        editorPanel.add(scrollPane, BorderLayout.CENTER);

        // RIGHT SIDE → Table
        tableModel = new DefaultTableModel(new String[]{"ID", "Title", "Code"}, 0);
        table = new JTable(tableModel);

        table.setRowHeight(28);
        table.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        table.getTableHeader().setFont(new Font("Segoe UI", Font.BOLD, 14));

        table.getSelectionModel().addListSelectionListener(this::onRowSelect);

        JScrollPane tableScroll = new JScrollPane(table);

        // 🔥 FINAL SPLIT
        JSplitPane splitPane = new JSplitPane(
                JSplitPane.HORIZONTAL_SPLIT,
                editorPanel,
                tableScroll
        );

        splitPane.setDividerLocation(800);
        splitPane.setResizeWeight(0.7);

        return splitPane;
    }

    // 🎯 Actions

    private void saveSnippet() {
        service.addSnippet(titleField.getText(), codeArea.getText());
        clearForm();
        loadData();
    }

    private void updateSnippet() {
        if (selectedId != -1) {
            service.updateSnippet(selectedId, titleField.getText(), codeArea.getText());
            clearForm();
            loadData();
        }
    }

    private void deleteSnippet() {
        if (selectedId != -1) {
            int confirm = JOptionPane.showConfirmDialog(this, "Delete snippet?");
            if (confirm == JOptionPane.YES_OPTION) {
                service.deleteSnippet(selectedId);
                clearForm();
                loadData();
            }
        }
    }

    private void search() {
        refreshTable(service.searchSnippets(searchField.getText()));
    }

    private void loadData() {
        refreshTable(service.getAllSnippets());
    }

    private void refreshTable(List<Snippet> list) {
        tableModel.setRowCount(0);

        for (Snippet s : list) {
            tableModel.addRow(new Object[]{
                    s.getId(),
                    s.getTitle(),
                    s.getCode()
            });
        }
    }

    private void clearForm() {
        titleField.setText("");
        codeArea.setText("");
        selectedId = -1;
        table.clearSelection();
    }

    private void onRowSelect(ListSelectionEvent e) {
        int row = table.getSelectedRow();
        if (row >= 0) {
            selectedId = (int) tableModel.getValueAt(row, 0);
            titleField.setText((String) tableModel.getValueAt(row, 1));
            codeArea.setText((String) tableModel.getValueAt(row, 2));
        }
    }
}


