package com.devworkbench.ui.snippet;

import com.devworkbench.model.Snippet;
import com.devworkbench.service.SnippetService;
import com.devworkbench.util.IconUtil;
import com.devworkbench.util.Theme;
import org.fife.ui.rsyntaxtextarea.*;
import org.fife.ui.rtextarea.RTextScrollPane;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.util.List;

public class SnippetPanel extends JPanel {

    private JTextField titleField, searchField;
    private RSyntaxTextArea codeArea;
    private JTable table;
    private DefaultTableModel model;
    private JLabel headerLabel, countLabel;

    private final SnippetService service = new SnippetService();
    private int selectedId = -1;

    public SnippetPanel() {
        setLayout(new BorderLayout(12, 12));
        setBackground(Theme.BACKGROUND);
        setBorder(BorderFactory.createEmptyBorder(12,12,12,12));

        add(createTop(), BorderLayout.NORTH);
        add(createSplit(), BorderLayout.CENTER);

        loadData();
    }

    private JPanel createTop() {
        JPanel panel = new JPanel(new BorderLayout(10,10));
        panel.setBackground(Theme.BACKGROUND);

        // Header
        headerLabel = new JLabel("Snippets | No Selection");
        headerLabel.setFont(new Font("Segoe UI", Font.BOLD, 17));
        headerLabel.setForeground(Color.WHITE);

        countLabel = new JLabel("Total: 0");
        countLabel.setForeground(Theme.TEXT_SECONDARY);

        JPanel header = new JPanel(new BorderLayout());
        header.setBackground(Theme.BACKGROUND);
        header.add(headerLabel, BorderLayout.WEST);
        header.add(countLabel, BorderLayout.EAST);

        panel.add(header, BorderLayout.NORTH);
        panel.add(createToolbar(), BorderLayout.CENTER);

        return panel;
    }

    private JPanel createToolbar() {
        JPanel panel = new JPanel(new BorderLayout(10,0));
        panel.setBackground(Theme.BACKGROUND);

        JPanel left = new JPanel(new FlowLayout(FlowLayout.LEFT,5,0));
        left.setBackground(Theme.BACKGROUND);

        left.add(btn("New","new", e->clear()));
        left.add(btn("Save","save", e->save()));
        left.add(btn("Update","update", e->update()));
        left.add(btn("Delete","delete", e->delete()));
        left.add(btn("Copy","copy", e->codeArea.copy()));

        JPanel right = new JPanel(new BorderLayout(5,0));
        right.setBackground(Theme.BACKGROUND);

        searchField = new JTextField();
        right.add(searchField, BorderLayout.CENTER);
        right.add(btn("Search","search", e->search()), BorderLayout.EAST);

        panel.add(left, BorderLayout.WEST);
        panel.add(right, BorderLayout.EAST);

        return panel;
    }

    private JButton btn(String t,String icon, java.awt.event.ActionListener a){
        JButton b=new JButton(t, IconUtil.get(icon));
        b.setFocusPainted(false);
        b.setMargin(new Insets(4,8,4,8));
        b.setBackground(Theme.CARD);
        b.setForeground(Color.WHITE);
        b.addActionListener(a);
        return b;
    }

    private JSplitPane createSplit() {

        // Editor
        JPanel editor = new JPanel(new BorderLayout(8,8));
        editor.setBackground(Theme.CARD);
        editor.setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(Theme.BORDER),
                BorderFactory.createEmptyBorder(10,10,10,10)
        ));

        titleField = new JTextField();
        titleField.setPreferredSize(new Dimension(0,35));

        codeArea = new RSyntaxTextArea();
        codeArea.setSyntaxEditingStyle(SyntaxConstants.SYNTAX_STYLE_JAVA);
        codeArea.setCodeFoldingEnabled(true);
        codeArea.setBackground(new Color(22,24,28));
        codeArea.setForeground(Color.WHITE);

        editor.add(titleField, BorderLayout.NORTH);
        editor.add(new RTextScrollPane(codeArea), BorderLayout.CENTER);

        // Table
        model = new DefaultTableModel(new String[]{"ID","Title","Code"},0);
        table = new JTable(model);

        table.setRowHeight(34);
        table.setBackground(Theme.CARD);
        table.setForeground(Color.WHITE);
        table.setShowGrid(false);

        table.getSelectionModel().addListSelectionListener(e->select());

        JScrollPane tablePane = new JScrollPane(table);
        tablePane.setBorder(BorderFactory.createLineBorder(Theme.BORDER));

        return new JSplitPane(JSplitPane.HORIZONTAL_SPLIT, editor, tablePane);
    }

    private void save(){ service.addSnippet(titleField.getText(),codeArea.getText()); loadData();}
    private void update(){ if(selectedId!=-1) service.updateSnippet(selectedId,titleField.getText(),codeArea.getText()); loadData();}
    private void delete(){ if(selectedId!=-1) service.deleteSnippet(selectedId); loadData();}
    private void search(){ refresh(service.searchSnippets(searchField.getText()));}

    private void loadData(){
        List<Snippet> list = service.getAllSnippets();
        refresh(list);
        countLabel.setText("Total: "+list.size());
    }

    private void refresh(List<Snippet> list){
        model.setRowCount(0);
        for(Snippet s:list){
            model.addRow(new Object[]{s.getId(),s.getTitle(),s.getCode()});
        }
    }

    private void select(){
        int r=table.getSelectedRow();
        if(r>=0){
            selectedId=(int)model.getValueAt(r,0);
            String title=(String)model.getValueAt(r,1);
            String code=(String)model.getValueAt(r,2);

            titleField.setText(title);
            codeArea.setText(code);
            headerLabel.setText("Snippets | "+title);
        }
    }

    private void clear(){
        selectedId=-1;
        titleField.setText("");
        codeArea.setText("");
        headerLabel.setText("Snippets | No Selection");
    }
}


