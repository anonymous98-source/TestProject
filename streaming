🔌 Step 3: DB Connection Utility

📄 db/DBConnection.java

package com.devworkbench.db;

import com.devworkbench.config.DBConfig;

import java.sql.Connection;
import java.sql.DriverManager;

public class DBConnection {

    private static Connection connection;

    public static Connection getConnection() {
        try {
            if (connection == null || connection.isClosed()) {
                connection = DriverManager.getConnection(
                        DBConfig.JDBC_URL,
                        DBConfig.USER,
                        DBConfig.PASSWORD
                );
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
        return connection;
    }
}

👉 Singleton-style connection (simple but effective for desktop app)


