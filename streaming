private JPanel createSidebar() {
    JPanel sidebar = new JPanel();
    sidebar.setLayout(new BorderLayout());
    sidebar.setPreferredSize(new Dimension(220, 0));
    sidebar.setBackground(new Color(28, 30, 34));

    // 🔝 Top Title
    JLabel title = new JLabel("  Developer Workbench");
    title.setForeground(Color.WHITE);
    title.setFont(new Font("Segoe UI", Font.BOLD, 14));
    title.setBorder(BorderFactory.createEmptyBorder(15, 10, 15, 10));

    sidebar.add(title, BorderLayout.NORTH);

    // 📂 Menu Panel
    JPanel menuPanel = new JPanel();
    menuPanel.setLayout(new GridLayout(0, 1, 5, 5));
    menuPanel.setBackground(new Color(28, 30, 34));

    menuPanel.add(createMenuItem("Snippets"));
    menuPanel.add(createMenuItem("API Tester"));
    menuPanel.add(createMenuItem("JSON Formatter"));
    menuPanel.add(createMenuItem("Notes"));
    menuPanel.add(createMenuItem("Logs"));
    menuPanel.add(createMenuItem("Settings"));

    sidebar.add(menuPanel, BorderLayout.CENTER);

    // 👤 Bottom Profile Section
    sidebar.add(createProfilePanel(), BorderLayout.SOUTH);

    return sidebar;
}


