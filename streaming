    public static String decryptPayload(String encryptedText, String secretKey) {

        String decryptedText = null;
        IvParameterSpec iv;
        try {
            byte[] encryptedTextByte = Base64.getDecoder().decode(encryptedText);
            byte[] keybyte = secretKey.getBytes(ENCODING);
            byte[] ivKey = Arrays.copyOf(keybyte, 16);
            iv = new IvParameterSpec(ivKey);
            SecretKey secretKeyObject = new SecretKeySpec(keybyte, AES_ALGO);

            Cipher cipher = Cipher.getInstance(AES_CIPHER);
            cipher.init(Cipher.DECRYPT_MODE, secretKeyObject, iv);
            byte[] decryptedByte = cipher.doFinal(encryptedTextByte);
            decryptedText = new String(decryptedByte);

        } catch (IOException | NoSuchAlgorithmException | NoSuchPaddingException | InvalidKeyException
                | InvalidAlgorithmParameterException | IllegalBlockSizeException | BadPaddingException e) {
            // throw new SbiCryptoException(e.getMessage());
            log.error("{}", e.getMessage());
        }
        return decryptedText;
    }

    public static String encryptAccessToken(String msg, PublicKey publicKey) {
        try {
            Cipher cipher = Cipher.getInstance(RSA_ALGO);
            cipher.init(Cipher.ENCRYPT_MODE, publicKey);
            return Base64.getEncoder().encodeToString(cipher.doFinal(msg.getBytes(ENCODING)));
        } catch (InvalidKeyException e) {
            throw new RuntimeException("InvalidKeyException", e);
        } catch (IllegalBlockSizeException e) {
            throw new RuntimeException("IllegalBlockSizeException", e);
        } catch (BadPaddingException e) {
            throw new RuntimeException("BadPaddingException", e);
        } catch (UnsupportedEncodingException e) {
            throw new RuntimeException("UnsupportedEncodingException", e);
        } catch (NoSuchAlgorithmException e) {
            throw new RuntimeException("NoSuchAlgorithmException", e);
        } catch (NoSuchPaddingException e) {
            throw new RuntimeException("NoSuchPaddingException", e);
        }
    }

    private static String getReferanceNo() {
        // Format : SBI-XX-YY-DDD-hh-MM-sss-NNNNNNNN
        StringBuffer str = new StringBuffer();
        str.append(BcorConstants.BANK_SHORT_CODE + BcorConstants.EIS_SOURCE_ID);
        LocalDateTime now = LocalDateTime.now();
        DateTimeFormatter format = DateTimeFormatter.ofPattern("yyDDDHHmmssSSS");
        String formatDateTime = now.format(format);
        if (EISRefNoCount.getCount() > 99999) {
            EISRefNoCount.setCount(0);
        }
        EISRefNoCount.setCount(EISRefNoCount.getCount() + 1);
        str.append(formatDateTime);
        str.append(StringUtils.leftPad(String.valueOf(EISRefNoCount.getCount()), 6, "0"));

        return str.toString();
    }

    private PublicKey getEISPublicKey() {
        try {
            return CryptoUtil
                    .getPublicKey(new ClassPathResource(certPath).getInputStream());
        } catch (IOException e) {
            log.error("IOException error while {} cause is {} ", e.getMessage(), e.fillInStackTrace());
        } catch (Exception e) {
            log.error("Exception error while {} cause is {} ", e.getMessage(), e.fillInStackTrace());
        }
        return null;
    }

    private String sendReqToEIS(String encryptedData, String url, String accessToken) throws RestClientException {
        log.debug("***{EIS}*** URL  is >> {} ", url);
        HttpHeaders headers = new HttpHeaders();
        headers.setContentType(MediaType.APPLICATION_JSON);
        // System.err.println("Access token :: " +accessToken);
        headers.set(BcorConstants.EIS_HEADER, accessToken);
        // prepare the request
        HttpEntity<String> entity = new HttpEntity<String>(encryptedData.toString(), headers);
        ResponseEntity<String> resp = restTemplate.exchange(url, HttpMethod.POST, entity, String.class);
        
        log.debug("response code >> {} ", resp.getStatusCode());
        if (resp.getStatusCode() != HttpStatus.OK) {
            log.error("***{EIS}*** request failed >> {} ", resp.getBody());
            return BcorConstants.BLANK;
        }
        return resp.getBody();
    }
