    public EmployeeInfo getEmpolyeeDetails(String pf) throws Exception {

        EmployeeInfo pfDetails = null;
        EISFetchPFReq plainReq = new EISFetchPFReq(pf, sourceId);
        String plainjson = CryptoUtil.getPlainJson(plainReq);

        String decryptedPfDetails = processEISRequest(pfUrl, plainjson);
        EmployeeInfo user = mapper.readValue(decryptedPfDetails, EmployeeInfo.class);
        log.debug("Non-Sensitive data : {Name: {}, PfId: {}}" , user.getName(), user.getPfId()); //added after observation by ISD
        if (decryptedPfDetails != null && !decryptedPfDetails.isEmpty()) {
            // Gson g = new Gson();
            // pfDetails = g.fromJson(decryptedPfDetails, EmployeeInfo.class);
            try {
                pfDetails = mapper.readValue(decryptedPfDetails, EmployeeInfo.class);
            } catch (JsonMappingException e) {
                log.error("{}", e.getMessage());
                throw new BcorException("Unable to fetch details of " + pf + ". Error in EIS Service");

            } catch (JsonProcessingException e) {
                log.error("{}", e.getMessage());
                throw new BcorException("Unable to fetch details of " + pf + ". Error in EIS Service");
            }
//            log.debug("getAccountInfo response is as", pfDetails);
            if (pfDetails.getResponseStatus().equalsIgnoreCase("1")) {
                throw new ResourceNotFoundException(pfDetails.getErrorDesc() + " Hint: Maybe it is an incorrect PF");
            }
        }
        return pfDetails;
    }

    private String processEISRequest(String url, String plianjson) throws Exception {
        String aesKey = EisUtil.getRandomSalt();
//        System.err.println("aesKey " + aesKey);
        String encryptedPayload = EisUtil.encryptPayload(plianjson, aesKey);
        // System.err.println(encryptedPayload);
        PrivateKey pk = CryptoUtil.getPrivatekey(keystorePath, keystoretoken, privateKeyForEis);
        String digitalSign = CryptoUtil.sign(plianjson, pk);
        String requestReferance = getReferanceNo();
        EISEncReq eisReq = new EISEncReq(digitalSign, requestReferance, encryptedPayload);
        String encryptedjson = CryptoUtil.getPlainJson(eisReq);
        // System.out.println(encryptedjson);
        PublicKey publicKey = getEISPublicKey();
        // System.err.println("PublicKey :: "+ publicKey);
        String accesstoken = EisUtil.encryptAccessToken(aesKey, publicKey);
//        log.info("access token after encryption :: {}",accesstoken);
        try {
            String responeString = sendReqToEIS(encryptedjson, url, accesstoken);
            log.debug("requestReferance {} {} {} response is as {}", requestReferance, aesKey, accesstoken, responeString);
            System.out.println("responeString"+responeString);  //added after observation by ISD
            if (responeString != null && !responeString.isEmpty()) {
                // Gson g = new Gson();
                // EISEncRes resp = g.fromJson(responeString, EISEncRes.class);
                EISEncRes resp = mapper.readValue(responeString, EISEncRes.class);
                String encryptedResponse = resp.getRESPONSE();
                System.err.println(encryptedResponse + " " + aesKey );
                String decryptedResponse = EisUtil.decryptPayload(encryptedResponse, aesKey);               
                return decryptedResponse;
            } else {
                log.error("EIS Request failed : request is {}", eisReq);
                throw new BcorException("EIS Down unable to fetch details from EIS");
            }
        } catch (RestClientException rs) {
            log.error("EIS Request failed : request is {}", eisReq);
            log.error("sendReqToEIS error while getting response {} cause is {} ", rs.getMessage(), rs.getCause());
            log.error("sendReqToEIS Exception while getting response from EIS {}", rs.fillInStackTrace());
            throw new BcorException("EIS service Error: " + rs.getMessage());
        }

    }
    
    public static String encryptPayload(String plainText, String secretKey) {
        String encryptedText = null;
        IvParameterSpec iv;
        SecretKey secretKeyObject;
        try {
            byte[] plainTextByte = plainText.getBytes();
            byte[] keybyte = secretKey.getBytes(ENCODING);
            byte[] ivKey = Arrays.copyOf(keybyte, 16);
            iv = new IvParameterSpec(ivKey);
            secretKeyObject = new SecretKeySpec(keybyte, AES_ALGO);
            Cipher cipher = Cipher.getInstance(AES_CIPHER);
            cipher.init(Cipher.ENCRYPT_MODE, secretKeyObject, iv);
            byte[] encryptedByte = cipher.doFinal(plainTextByte);
            encryptedText = Base64.getEncoder().encodeToString(encryptedByte);

        } catch (UnsupportedEncodingException | NoSuchAlgorithmException | NoSuchPaddingException | InvalidKeyException
                | InvalidAlgorithmParameterException
                | IllegalBlockSizeException | BadPaddingException e) {
            // throw new SbiCryptoException(e.getMessage());
            log.error("{}", e.getMessage());
        }
        return encryptedText;
    }

