🗄️ Step 5: DAO Layer (REAL DB OPERATIONS)

📄 dao/SnippetDAO.java

package com.devworkbench.dao;

import com.devworkbench.db.DBConnection;
import com.devworkbench.model.Snippet;

import java.sql.*;
import java.util.ArrayList;
import java.util.List;

public class SnippetDAO {

    public void save(Snippet snippet) {
        String sql = "INSERT INTO snippet(title, code) VALUES (?, ?)";

        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, snippet.getTitle());
            ps.setString(2, snippet.getCode());
            ps.executeUpdate();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    public List<Snippet> findAll() {
        List<Snippet> list = new ArrayList<>();
        String sql = "SELECT * FROM snippet";

        try (Connection conn = DBConnection.getConnection();
             Statement stmt = conn.createStatement();
             ResultSet rs = stmt.executeQuery(sql)) {

            while (rs.next()) {
                Snippet s = new Snippet(
                        rs.getInt("id"),
                        rs.getString("title"),
                        rs.getString("code")
                );
                list.add(s);
            }

        } catch (Exception e) {
            e.printStackTrace();
        }

        return list;
    }

    public void delete(int id) {
        String sql = "DELETE FROM snippet WHERE id=?";

        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setInt(1, id);
            ps.executeUpdate();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}


