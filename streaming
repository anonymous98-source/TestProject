I would not use multiple repository calls.

Instead, use 2 repository methods.

Repository

Step 1 - Fetch customer details

@Query("""
    SELECT
        fs.customerId AS customerId,
        fs.registrationId AS registrationId,
        fs.subscriptionId AS subscriptionId
    FROM FedexSubscriptionEntity fs
    WHERE fs.customerId = :customerId
    """)
Optional<FedexSubscriptionProjection> findFedexSubscription(
        String customerId);


---

Step 2

long countBySubscriptionId(String subscriptionId);


---

Step 3

boolean existsBySubscriptionIdAndAccountNumber(
        String subscriptionId,
        String accountNumber);


---

Service

@Override
public FedexSubscriptionResponse getFedexSubscription(
        String customerId,
        String accountNumber) {

    FedexSubscriptionProjection projection =
            repository.findFedexSubscription(customerId)
                    .orElseThrow(() ->
                            new ResourceNotFoundException("Customer not found"));

    FedexSubscriptionResponse response =
            new FedexSubscriptionResponse();

    response.setCustomerId(projection.getCustomerId());
    response.setRegistrationId(projection.getRegistrationId());

    long accountCount =
            accountRepository.countBySubscriptionId(
                    projection.getSubscriptionId());

    // Business Rule 1
    if (accountCount > 500) {

        response.setSubscriptionId(null);

        response.setAccountNumber(accountNumber);

        return response;
    }

    response.setSubscriptionId(
            projection.getSubscriptionId());

    boolean accountExists =
            accountRepository.existsBySubscriptionIdAndAccountNumber(
                    projection.getSubscriptionId(),
                    accountNumber);

    // Business Rule 2
    if (!accountExists) {

        response.setAccountNumber(null);

        return response;
    }

    // Business Rule 3
    response.setAccountNumber(accountNumber);

    return response;
}


