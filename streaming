package com.devworkbench.ui.main;

import com.devworkbench.ui.snippet.SnippetPanel;
import com.devworkbench.util.IconUtil;
import com.devworkbench.util.Theme;
import com.formdev.flatlaf.FlatDarkLaf;
import com.formdev.flatlaf.FlatLightLaf;

import javax.swing.*;
import java.awt.*;

public class MainFrame extends JFrame {

    private CardLayout cardLayout;
    private JPanel contentPanel;
    private JButton selectedMenu;

    public MainFrame() {
        initTheme();

        setTitle("Developer Workbench");
        setSize(1400, 800);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(EXIT_ON_CLOSE);

        setLayout(new BorderLayout());

        add(createTopBar(), BorderLayout.NORTH);
        add(createSidebar(), BorderLayout.WEST);
        add(createContent(), BorderLayout.CENTER);
    }

    private void initTheme() {
        try {
            FlatDarkLaf.setup();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    // 🔝 TOP BAR
    private JPanel createTopBar() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(Theme.BACKGROUND);
        panel.setBorder(BorderFactory.createEmptyBorder(8, 10, 8, 10));

        JLabel title = new JLabel("Developer Workbench");
        title.setForeground(Color.WHITE);
        title.setFont(new Font("Segoe UI", Font.BOLD, 15));

        // 🌙 Theme Toggle
        JToggleButton toggle = new JToggleButton("🌙");
        toggle.addActionListener(e -> {
            try {
                if (toggle.isSelected()) {
                    FlatLightLaf.setup();
                } else {
                    FlatDarkLaf.setup();
                }
                SwingUtilities.updateComponentTreeUI(this);
            } catch (Exception ex) {
                ex.printStackTrace();
            }
        });

        panel.add(title, BorderLayout.WEST);
        panel.add(toggle, BorderLayout.EAST);

        return panel;
    }

    // 🧭 SIDEBAR
    private JPanel createSidebar() {
        JPanel sidebar = new JPanel(new BorderLayout());
        sidebar.setBackground(Theme.SIDEBAR);
        sidebar.setPreferredSize(new Dimension(240, 0));

        JPanel menu = new JPanel();
        menu.setLayout(new BoxLayout(menu, BoxLayout.Y_AXIS));
        menu.setBackground(Theme.SIDEBAR);

        // 🔥 MAIN MENU
        menu.add(createMenuItem("Snippets", "code", true));
        menu.add(createMenuItem("API Tester", "api", false));
        menu.add(createMenuItem("JSON Formatter", "json", false));
        menu.add(createMenuItem("Notes", "notes", false));
        menu.add(createMenuItem("Logs", "logs", false));
        menu.add(createMenuItem("Settings", "settings", false));

        // 📂 COLLECTIONS LABEL
        JLabel section = new JLabel("  COLLECTIONS");
        section.setForeground(Theme.TEXT_SECONDARY);
        section.setFont(new Font("Segoe UI", Font.BOLD, 11));
        section.setBorder(BorderFactory.createEmptyBorder(15, 10, 5, 0));

        menu.add(section);

        // 📊 COLLECTION ITEMS
        menu.add(createCollectionItem("Java", 5));
        menu.add(createCollectionItem("SQL", 3));
        menu.add(createCollectionItem("JSON", 2));

        sidebar.add(menu, BorderLayout.CENTER);
        sidebar.add(createProfilePanel(), BorderLayout.SOUTH);

        return sidebar;
    }

    // 🧩 MENU ITEM
    private JButton createMenuItem(String text, String icon, boolean selected) {
        JButton btn = new JButton(text, IconUtil.get(icon));

        btn.setHorizontalAlignment(SwingConstants.LEFT);
        btn.setIconTextGap(10);
        btn.setFocusPainted(false);
        btn.setBorder(BorderFactory.createEmptyBorder(10, 15, 10, 10));
        btn.setFont(new Font("Segoe UI", Font.PLAIN, 13));
        btn.setCursor(new Cursor(Cursor.HAND_CURSOR));

        if (selected) {
            btn.setBackground(Theme.ACCENT);
            btn.setForeground(Color.WHITE);
            selectedMenu = btn;
        } else {
            btn.setBackground(Theme.SIDEBAR);
            btn.setForeground(Theme.TEXT_SECONDARY);
        }

        btn.addActionListener(e -> {
            switchPanel(text);
            highlight(btn);
        });

        return btn;
    }

    // 🔄 HIGHLIGHT
    private void highlight(JButton btn) {
        if (selectedMenu != null) {
            selectedMenu.setBackground(Theme.SIDEBAR);
            selectedMenu.setForeground(Theme.TEXT_SECONDARY);
        }

        btn.setBackground(Theme.ACCENT);
        btn.setForeground(Color.WHITE);
        selectedMenu = btn;
    }

    // 📂 COLLECTION ITEM
    private JPanel createCollectionItem(String name, int count) {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(Theme.SIDEBAR);
        panel.setBorder(BorderFactory.createEmptyBorder(8, 20, 8, 10));

        JLabel label = new JLabel(name);
        label.setForeground(Theme.TEXT_PRIMARY);

        JLabel badge = new JLabel(String.valueOf(count));
        badge.setForeground(Color.WHITE);
        badge.setBackground(Theme.ACCENT);
        badge.setOpaque(true);
        badge.setBorder(BorderFactory.createEmptyBorder(2, 6, 2, 6));

        panel.add(label, BorderLayout.WEST);
        panel.add(badge, BorderLayout.EAST);

        return panel;
    }

    // 👤 PROFILE PANEL
    private JPanel createProfilePanel() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(new Color(35, 37, 42));
        panel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        JLabel name = new JLabel("Rugved Deshpande");
        name.setForeground(Color.WHITE);
        name.setFont(new Font("Segoe UI", Font.BOLD, 13));

        JLabel role = new JLabel("Full Stack Developer");
        role.setForeground(Theme.TEXT_SECONDARY);
        role.setFont(new Font("Segoe UI", Font.PLAIN, 11));

        JLabel status = new JLabel("● Online");
        status.setForeground(new Color(0, 200, 120));

        JPanel text = new JPanel(new GridLayout(3, 1));
        text.setBackground(panel.getBackground());
        text.add(name);
        text.add(role);
        text.add(status);

        panel.add(text, BorderLayout.CENTER);

        return panel;
    }

    // 🧩 CONTENT AREA
    private JPanel createContent() {
        cardLayout = new CardLayout();
        contentPanel = new JPanel(cardLayout);

        contentPanel.add(new SnippetPanel(), "Snippets");
        contentPanel.add(new JLabel("API Tester Coming Soon"), "API Tester");
        contentPanel.add(new JLabel("JSON Formatter Coming Soon"), "JSON Formatter");
        contentPanel.add(new JLabel("Notes Coming Soon"), "Notes");
        contentPanel.add(new JLabel("Logs Coming Soon"), "Logs");
        contentPanel.add(new JLabel("Settings Coming Soon"), "Settings");

        return contentPanel;
    }

    private void switchPanel(String name) {
        cardLayout.show(contentPanel, name);
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new MainFrame().setVisible(true));
    }
}


