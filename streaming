Service Test (Matching Your Project Style)

@ExtendWith(MockitoExtension.class)
class FedexSubscriptionServiceImplTest {

    @Mock
    private FedexSubscriptionRepository fedexSubscriptionRepository;

    @InjectMocks
    private FedexSubscriptionServiceImpl fedexSubscriptionService;

    @Test
    @DisplayName("Fetch FedEx subscription details - Success")
    void testGetFedexSubscription_SuccessScenario() {

        UUID customerId = UUID.randomUUID();
        UUID registrationId = UUID.randomUUID();
        UUID subscriptionId = UUID.randomUUID();

        String accountNumber = "123456";

        FedexSubscriptionProjection projection =
                mock(FedexSubscriptionProjection.class);

        when(fedexSubscriptionRepository.existsByCustomerId(customerId))
                .thenReturn(true);

        when(fedexSubscriptionRepository.findSubscriptionDetails(
                customerId,
                accountNumber))
                .thenReturn(Optional.of(projection));

        when(projection.getRegistrationId())
                .thenReturn(registrationId);

        when(projection.getSubscriptionId())
                .thenReturn(subscriptionId);

        when(projection.getAccountNumber())
                .thenReturn(accountNumber);

        FedexSubscriptionResponse response =
                fedexSubscriptionService.getFedexSubscription(
                        customerId,
                        accountNumber);

        assertNotNull(response);
        assertEquals(registrationId,
                response.getRegistrationId());

        assertEquals(subscriptionId,
                response.getSubscriptionId());

        assertEquals(accountNumber,
                response.getAccountNumber());
    }

    @Test
    @DisplayName("Fetch FedEx subscription details - Customer Not Found")
    void testGetFedexSubscription_CustomerNotFoundScenario() {

        UUID customerId = UUID.randomUUID();

        when(fedexSubscriptionRepository.existsByCustomerId(customerId))
                .thenReturn(false);

        FedexSubscriptionResponse response =
                fedexSubscriptionService.getFedexSubscription(
                        customerId,
                        "123456");

        assertNull(response);

        verify(fedexSubscriptionRepository)
                .existsByCustomerId(customerId);

        verifyNoMoreInteractions(
                fedexSubscriptionRepository);
    }

    @Test
    @DisplayName("Fetch FedEx subscription details - Subscription Not Found")
    void testGetFedexSubscription_SubscriptionNotFoundScenario() {

        UUID customerId = UUID.randomUUID();

        String accountNumber = "123456";

        when(fedexSubscriptionRepository.existsByCustomerId(customerId))
                .thenReturn(true);

        when(fedexSubscriptionRepository.findSubscriptionDetails(
                customerId,
                accountNumber))
                .thenReturn(Optional.empty());

        FedexSubscriptionResponse response =
                fedexSubscriptionService.getFedexSubscription(
                        customerId,
                        accountNumber);

        assertNull(response);
    }
}


