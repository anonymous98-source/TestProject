package com.devworkbench.util;

import java.awt.*;

public class Theme {

    public static final Color BACKGROUND = new Color(16, 18, 22);
    public static final Color SIDEBAR = new Color(20, 22, 26);
    public static final Color CARD = new Color(28, 30, 36);

    public static final Color ACCENT = new Color(140, 100, 255);

    public static final Color TEXT_PRIMARY = new Color(235, 235, 235);
