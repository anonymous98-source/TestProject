package com.cardinalhealth.advship.preferences.api.service.impl;

import com.cardinalhealth.advship.preferences.api.dto.response.FedexSubscriptionResponse;
import com.cardinalhealth.advship.preferences.api.repository.FedexSubscriptionRepository;
import com.cardinalhealth.advship.preferences.api.repository.projection.FedexSubscriptionProjection;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.Optional;
import java.util.UUID;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class FedexSubscriptionServiceImplTest {

    @Mock
    private FedexSubscriptionRepository repository;

    @InjectMocks
    private FedexSubscriptionServiceImpl service;

    @Test
    void shouldReturnSubscriptionDetails() {

        UUID customerId = UUID.randomUUID();
        UUID registrationId = UUID.randomUUID();
        UUID subscriptionId = UUID.randomUUID();

        String accountNumber = "123456";

        FedexSubscriptionProjection projection =
                mock(FedexSubscriptionProjection.class);

        when(repository.existsByCustomerId(customerId))
                .thenReturn(true);

        when(repository.findSubscriptionDetails(
                customerId,
                accountNumber))
                .thenReturn(Optional.of(projection));

        when(projection.getRegistrationId())
                .thenReturn(registrationId);

        when(projection.getSubscriptionId())
                .thenReturn(subscriptionId);

        when(projection.getAccountNumber())
                .thenReturn(accountNumber);

        FedexSubscriptionResponse response =
                service.getFedexSubscription(
                        customerId,
                        accountNumber);

        assertNotNull(response);
        assertEquals(registrationId, response.registrationId());
        assertEquals(subscriptionId, response.subscriptionId());
        assertEquals(accountNumber, response.accountNumber());

        verify(repository).existsByCustomerId(customerId);
        verify(repository).findSubscriptionDetails(
                customerId,
                accountNumber);
    }

    @Test
    void shouldReturnNullWhenCustomerDoesNotExist() {

        UUID customerId = UUID.randomUUID();

        when(repository.existsByCustomerId(customerId))
                .thenReturn(false);

        FedexSubscriptionResponse response =
                service.getFedexSubscription(
                        customerId,
                        "123456");

        assertNull(response);

        verify(repository).existsByCustomerId(customerId);

        verify(repository, never())
                .findSubscriptionDetails(any(), any());
    }

    @Test
    void shouldReturnNullWhenSubscriptionNotFound() {

        UUID customerId = UUID.randomUUID();

        String accountNumber = "123456";

        when(repository.existsByCustomerId(customerId))
                .thenReturn(true);

        when(repository.findSubscriptionDetails(
                customerId,
                accountNumber))
                .thenReturn(Optional.empty());

        FedexSubscriptionResponse response =
                service.getFedexSubscription(
                        customerId,
                        accountNumber);

        assertNull(response);

        verify(repository).existsByCustomerId(customerId);

        verify(repository).findSubscriptionDetails(
                customerId,
                accountNumber);
    }
}


