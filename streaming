package com.devworkbench.ui.main;

import com.formdev.flatlaf.FlatDarkLaf;
import com.devworkbench.ui.snippet.SnippetPanel;

import javax.swing.*;
import java.awt.*;

public class MainFrame extends JFrame {

    private CardLayout cardLayout;
    private JPanel contentPanel;

    public MainFrame() {
        initTheme();
        setTitle("Developer Workbench");
        setSize(1400, 800);
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setLocationRelativeTo(null);

        setLayout(new BorderLayout());

        add(createSidebar(), BorderLayout.WEST);
        add(createContent(), BorderLayout.CENTER);
        add(createStatusBar(), BorderLayout.SOUTH);
    }

    private void initTheme() {
        try {
            FlatDarkLaf.setup();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    // 🧭 Sidebar
    private JPanel createSidebar() {
        JPanel panel = new JPanel();
        panel.setLayout(new BorderLayout());
        panel.setPreferredSize(new Dimension(220, 0));

        String[] menu = {
                "Snippets",
                "API Tester",
                "JSON Formatter",
                "Notes",
                "Logs",
                "Settings"
        };

        JList<String> list = new JList<>(menu);
        list.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        list.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
        list.setSelectedIndex(0);

        list.addListSelectionListener(e -> switchPanel(list.getSelectedValue()));

        panel.add(new JScrollPane(list), BorderLayout.CENTER);

        return panel;
    }

    // 🧩 Content Area
    private JPanel createContent() {
        cardLayout = new CardLayout();
        contentPanel = new JPanel(cardLayout);

        contentPanel.add(new SnippetPanel(), "Snippets");

        // Placeholder panels (we’ll build later)
        contentPanel.add(new JLabel("API Tester Coming Soon"), "API Tester");
        contentPanel.add(new JLabel("JSON Formatter Coming Soon"), "JSON Formatter");
        contentPanel.add(new JLabel("Notes Coming Soon"), "Notes");
        contentPanel.add(new JLabel("Logs Coming Soon"), "Logs");
        contentPanel.add(new JLabel("Settings Coming Soon"), "Settings");

        return contentPanel;
    }

    // 🔽 Status Bar
    private JPanel createStatusBar() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBorder(BorderFactory.createEmptyBorder(5, 10, 5, 10));

        JLabel left = new JLabel("Ready");
        JLabel right = new JLabel("Dev Workbench v1.0");

        panel.add(left, BorderLayout.WEST);
        panel.add(right, BorderLayout.EAST);

        return panel;
    }

    private void switchPanel(String name) {
        cardLayout.show(contentPanel, name);
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new MainFrame().setVisible(true));
    }
}


