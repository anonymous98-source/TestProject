package com.devworkbench.ui.snippet;

import com.devworkbench.model.Snippet;
import com.devworkbench.service.SnippetService;
import com.devworkbench.util.IconUtil;
import com.devworkbench.util.Theme;
import org.fife.ui.rsyntaxtextarea.RSyntaxTextArea;
import org.fife.ui.rsyntaxtextarea.SyntaxConstants;
import org.fife.ui.rtextarea.RTextScrollPane;

import javax.swing.*;
import javax.swing.event.ListSelectionEvent;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.util.List;

public class SnippetPanel extends JPanel {

    private JTextField titleField;
    private JTextField searchField;
    private RSyntaxTextArea codeArea;
    private JTable table;
    private DefaultTableModel tableModel;
    private JComboBox<String> languageBox;
    private JLabel headerLabel;
    private JLabel countLabel;

    private final SnippetService service = new SnippetService();
    private int selectedId = -1;

    public SnippetPanel() {
        setLayout(new BorderLayout(10, 10));
        setBackground(Theme.BACKGROUND);
        setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        add(createTopPanel(), BorderLayout.NORTH);
        add(createMainSplit(), BorderLayout.CENTER);

        loadData();
    }

    // 🔝 TOP PANEL (Header + Toolbar + Search)
    private JPanel createTopPanel() {
        JPanel panel = new JPanel(new BorderLayout(10, 10));
        panel.setBackground(Theme.BACKGROUND);

        panel.add(createHeader(), BorderLayout.NORTH);
        panel.add(createToolbar(), BorderLayout.CENTER);

        return panel;
    }

    // 🧠 HEADER
    private JPanel createHeader() {
        JPanel panel = new JPanel(new BorderLayout());
        panel.setBackground(Theme.BACKGROUND);

        headerLabel = new JLabel("Snippets | No Selection");
        headerLabel.setFont(new Font("Segoe UI", Font.BOLD, 16));
        headerLabel.setForeground(Color.WHITE);

        countLabel = new JLabel("Total: 0");
        countLabel.setForeground(Theme.TEXT_SECONDARY);

        panel.add(headerLabel, BorderLayout.WEST);
        panel.add(countLabel, BorderLayout.EAST);

        return panel;
    }

    // 🎛️ TOOLBAR
    private JPanel createToolbar() {
        JPanel panel = new JPanel(new BorderLayout(10, 10));
        panel.setBackground(Theme.BACKGROUND);

        JPanel left = new JPanel(new FlowLayout(FlowLayout.LEFT, 5, 0));
        left.setBackground(Theme.BACKGROUND);

        JButton newBtn = createButton("New", "new");
        JButton saveBtn = createButton("Save", "save");
        JButton updateBtn = createButton("Update", "update");
        JButton deleteBtn = createButton("Delete", "delete");
        JButton copyBtn = createButton("Copy", "copy");

        newBtn.addActionListener(e -> clearForm());
        saveBtn.addActionListener(e -> saveSnippet());
        updateBtn.addActionListener(e -> updateSnippet());
        deleteBtn.addActionListener(e -> deleteSnippet());
        copyBtn.addActionListener(e -> codeArea.copy());

        left.add(newBtn);
        left.add(saveBtn);
        left.add(updateBtn);
        left.add(deleteBtn);
        left.add(copyBtn);

        // 🔍 Search
        JPanel right = new JPanel(new BorderLayout(5, 0));
        right.setBackground(Theme.BACKGROUND);

        searchField = new JTextField();
        JButton searchBtn = createButton("Search", "search");

        searchBtn.addActionListener(e -> search());

        right.add(searchField, BorderLayout.CENTER);
        right.add(searchBtn, BorderLayout.EAST);

        panel.add(left, BorderLayout.WEST);
        panel.add(right, BorderLayout.EAST);

        return panel;
    }

    // 🎛️ BUTTON STYLE
    private JButton createButton(String text, String icon) {
        JButton btn = new JButton(text, IconUtil.get(icon));

        btn.setFocusPainted(false);
        btn.setFont(new Font("Segoe UI", Font.PLAIN, 12));
        btn.setMargin(new Insets(4, 8, 4, 8));
        btn.setBackground(Theme.CARD);
        btn.setForeground(Color.WHITE);
        btn.setCursor(new Cursor(Cursor.HAND_CURSOR));

        return btn;
    }

    // 🧩 MAIN SPLIT
    private JSplitPane createMainSplit() {

        // LEFT → Editor
        JPanel editor = new JPanel(new BorderLayout(8, 8));
        editor.setBackground(Theme.CARD);

        JPanel topRow = new JPanel(new BorderLayout(10, 5));
        topRow.setBackground(Theme.CARD);

        titleField = new JTextField();
        titleField.setPreferredSize(new Dimension(0, 35));

        languageBox = new JComboBox<>(new String[]{"Java", "SQL", "JSON", "XML"});
        languageBox.setPreferredSize(new Dimension(120, 35));

        topRow.add(titleField, BorderLayout.CENTER);
        topRow.add(languageBox, BorderLayout.EAST);

        codeArea = new RSyntaxTextArea();
        codeArea.setSyntaxEditingStyle(SyntaxConstants.SYNTAX_STYLE_JAVA);
        codeArea.setCodeFoldingEnabled(true);
        codeArea.setFont(new Font("Consolas", Font.PLAIN, 14));

        codeArea.setBackground(new Color(25, 27, 32));
        codeArea.setForeground(new Color(220, 220, 220));
        codeArea.setCaretColor(Color.WHITE);

        RTextScrollPane scroll = new RTextScrollPane(codeArea);

        editor.add(topRow, BorderLayout.NORTH);
        editor.add(scroll, BorderLayout.CENTER);

        // RIGHT → Table
        tableModel = new DefaultTableModel(new String[]{"ID", "Title", "Code"}, 0);
        table = new JTable(tableModel);

        table.setRowHeight(30);
        table.setBackground(Theme.CARD);
        table.setForeground(Color.WHITE);
        table.setShowGrid(false);

        table.getSelectionModel().addListSelectionListener(this::onRowSelect);

        JScrollPane tableScroll = new JScrollPane(table);

        JSplitPane split = new JSplitPane(
                JSplitPane.HORIZONTAL_SPLIT,
                editor,
                tableScroll
        );

        split.setDividerLocation(750);
        split.setResizeWeight(0.7);

        return split;
    }

    // 🎯 ACTIONS

    private void saveSnippet() {
        service.addSnippet(titleField.getText(), codeArea.getText());
        clearForm();
        loadData();
    }

    private void updateSnippet() {
        if (selectedId != -1) {
            service.updateSnippet(selectedId, titleField.getText(), codeArea.getText());
            clearForm();
            loadData();
        }
    }

    private void deleteSnippet() {
        if (selectedId != -1) {
            service.deleteSnippet(selectedId);
            clearForm();
            loadData();
        }
    }

    private void search() {
        refreshTable(service.searchSnippets(searchField.getText()));
    }

    private void loadData() {
        List<Snippet> list = service.getAllSnippets();
        refreshTable(list);
        countLabel.setText("Total: " + list.size());
    }

    private void refreshTable(List<Snippet> list) {
        tableModel.setRowCount(0);

        for (Snippet s : list) {
            tableModel.addRow(new Object[]{
                    s.getId(),
                    s.getTitle(),
                    s.getCode()
            });
        }
    }

    private void clearForm() {
        titleField.setText("");
        codeArea.setText("");
        selectedId = -1;
        table.clearSelection();
        headerLabel.setText("Snippets | No Selection");
    }

    private void onRowSelect(ListSelectionEvent e) {
        int row = table.getSelectedRow();
        if (row >= 0) {
            selectedId = (int) tableModel.getValueAt(row, 0);
            String title = (String) tableModel.getValueAt(row, 1);
            String code = (String) tableModel.getValueAt(row, 2);

            titleField.setText(title);
            codeArea.setText(code);

            headerLabel.setText("Snippets | " + title);
        }
    }
}


