package com.devworkbench.util;

import com.formdev.flatlaf.extras.FlatSVGIcon;

import javax.swing.*;

public class IconUtil {

    public static Icon get(String name) {
        return new FlatSVGIcon("icons/" + name + ".svg", 16, 16);
    }
}


