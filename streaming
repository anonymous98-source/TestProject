private JPanel createCollectionItem(String name, int count) {
    JPanel panel = new JPanel(new BorderLayout());
    panel.setBackground(Theme.SIDEBAR);
    panel.setBorder(BorderFactory.createEmptyBorder(8, 20, 8, 10));

    JLabel label = new JLabel(name);
    label.setForeground(Theme.TEXT_PRIMARY);

    JLabel badge = new JLabel(String.valueOf(count));
    badge.setForeground(Color.WHITE);
    badge.setBackground(Theme.ACCENT);
    badge.setOpaque(true);
    badge.setBorder(BorderFactory.createEmptyBorder(2, 6, 2, 6));

    panel.add(label, BorderLayout.WEST);
    panel.add(badge, BorderLayout.EAST);

    return panel;
}


