@ExtendWith(MockitoExtension.class)
class FedexSubscriptionServiceImplTest {

    @Mock
    private FedexSubscriptionRepository repository;

    @InjectMocks
    private FedexSubscriptionServiceImpl service;

    @Test
    void shouldReturnSubscriptionDetails() {

        UUID customerId = UUID.randomUUID();

        FedexSubscriptionEntity entity = FedexSubscriptionEntity.builder()
                .registrationId(UUID.randomUUID())
                .subscriptionId(UUID.randomUUID())
                .customerId(customerId)
                .build();

        when(repository.findByCustomerId(customerId))
                .thenReturn(Optional.of(entity));

        FedexSubscriptionResponse response =
                service.getFedexSubscription(customerId);

        assertNotNull(response);
        assertEquals(entity.getRegistrationId(),
                response.registrationId());
        assertEquals(entity.getSubscriptionId(),
                response.subscriptionId());
    }

    @Test
    void shouldReturnNullWhenSubscriptionNotFound() {

        UUID customerId = UUID.randomUUID();

        when(repository.findByCustomerId(customerId))
                .thenReturn(Optional.empty());

        FedexSubscriptionResponse response =
                service.getFedexSubscription(customerId);

        assertNull(response);
    }
}


