package com.devworkbench.ui.snippet;

import com.devworkbench.model.Snippet;
import com.devworkbench.service.SnippetService;

import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.util.List;

public class SnippetPanel extends JPanel {

    private JTextField titleField;
    private JTextArea codeArea;
    private JTable table;
    private DefaultTableModel tableModel;

    private final SnippetService service = new SnippetService();

    public SnippetPanel() {
        setLayout(new BorderLayout());

        // Top panel (input)
        JPanel inputPanel = new JPanel(new GridLayout(3, 1));

        titleField = new JTextField();
        codeArea = new JTextArea(5, 20);

        JButton saveBtn = new JButton("Save Snippet");

        inputPanel.add(new JLabel("Title:"));
        inputPanel.add(titleField);
        inputPanel.add(new JScrollPane(codeArea));
        inputPanel.add(saveBtn);

        add(inputPanel, BorderLayout.NORTH);

        // Table
        tableModel = new DefaultTableModel(new String[]{"ID", "Title", "Code"}, 0);
        table = new JTable(tableModel);

        add(new JScrollPane(table), BorderLayout.CENTER);

        // Button action
        saveBtn.addActionListener(e -> saveSnippet());

        loadData();
    }

    private void saveSnippet() {
        String title = titleField.getText();
        String code = codeArea.getText();

        service.addSnippet(title, code);

        titleField.setText("");
        codeArea.setText("");

        loadData();
    }

    private void loadData() {
        tableModel.setRowCount(0);

        List<Snippet> list = service.getAllSnippets();

        for (Snippet s : list) {
            tableModel.addRow(new Object[]{
                    s.getId(),
                    s.getTitle(),
                    s.getCode()
            });
        }
    }
}


