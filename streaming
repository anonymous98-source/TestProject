Global Exception Handler

If your project already has one, add a handler there.

Otherwise:

package com.cardinalhealth.advship.preferences.api.exception;

import com.cardinalhealth.advship.preferences.api.dto.response.ErrorResponse;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.bind.annotation.RestControllerAdvice;

import java.time.LocalDateTime;

@RestControllerAdvice
public class GlobalExceptionHandler {

    @ExceptionHandler(FedexSubscriptionNotFoundException.class)
    public ResponseEntity<ErrorResponse> handleSubscriptionNotFound(
            FedexSubscriptionNotFoundException ex) {

        return ResponseEntity.status(HttpStatus.NOT_FOUND)
                .body(ErrorResponse.builder()
                        .message(ex.getMessage())
                        .errorCode("FEDEX_SUBSCRIPTION_NOT_FOUND")
                        .timestamp(LocalDateTime.now())
                        .build());
    }
}


