private JButton createMenuItem(String text, String icon, boolean selected) {
    JButton btn = new JButton(text, IconUtil.get(icon));

    btn.setHorizontalAlignment(SwingConstants.LEFT);
    btn.setIconTextGap(10);
    btn.setFocusPainted(false);
    btn.setBorder(BorderFactory.createEmptyBorder(10, 15, 10, 10));
    btn.setFont(new Font("Segoe UI", Font.PLAIN, 13));
    btn.setCursor(new Cursor(Cursor.HAND_CURSOR));

    if (selected) {
        btn.setBackground(Theme.ACCENT);
        btn.setForeground(Color.WHITE);
    } else {
        btn.setBackground(Theme.SIDEBAR);
        btn.setForeground(Theme.TEXT_SECONDARY);
    }

    btn.addActionListener(e -> {
        switchPanel(text);
        highlightSelected(btn);
    });

    return btn;
}


