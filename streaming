package com.devworkbench.ui.main;

import com.devworkbench.ui.snippet.SnippetPanel;
import com.devworkbench.util.IconUtil;
import com.devworkbench.util.Theme;
import com.formdev.flatlaf.FlatDarkLaf;

import javax.swing.*;
import java.awt.*;

public class MainFrame extends JFrame {

    private CardLayout layout = new CardLayout();
    private JPanel content = new JPanel(layout);
    private JButton selected;

    public MainFrame() {
        FlatDarkLaf.setup();

        setTitle("Developer Workbench");
        setSize(1400,800);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(EXIT_ON_CLOSE);

        setLayout(new BorderLayout());

        add(top(), BorderLayout.NORTH);
        add(sidebar(), BorderLayout.WEST);
        add(main(), BorderLayout.CENTER);
    }

    private JPanel top(){
        JPanel p=new JPanel(new BorderLayout());
        p.setBackground(Theme.BACKGROUND);
        p.setBorder(BorderFactory.createEmptyBorder(8,10,8,10));

        JLabel t=new JLabel("Developer Workbench");
        t.setForeground(Color.WHITE);
        t.setFont(new Font("Segoe UI",Font.BOLD,15));

        p.add(t,BorderLayout.WEST);
        return p;
    }

    private JPanel sidebar(){
        JPanel s=new JPanel(new BorderLayout());
        s.setBackground(Theme.SIDEBAR);
        s.setPreferredSize(new Dimension(240,0));

        JPanel menu=new JPanel();
        menu.setLayout(new BoxLayout(menu,BoxLayout.Y_AXIS));
        menu.setBackground(Theme.SIDEBAR);

        menu.add(item("Snippets","code",true));
        menu.add(item("API Tester","api",false));
        menu.add(item("JSON Formatter","json",false));

        JLabel sec=new JLabel("  COLLECTIONS");
        sec.setForeground(Theme.TEXT_SECONDARY);
        sec.setFont(new Font("Segoe UI",Font.BOLD,11));
        sec.setBorder(BorderFactory.createEmptyBorder(15,10,5,0));

        menu.add(sec);
        menu.add(collection("Java",5));
        menu.add(collection("SQL",3));

        s.add(menu,BorderLayout.CENTER);
        s.add(profile(),BorderLayout.SOUTH);

        return s;
    }

    private JButton item(String t,String icon,boolean sel){
        JButton b=new JButton(t, IconUtil.get(icon));
        b.setHorizontalAlignment(SwingConstants.LEFT);
        b.setBorder(BorderFactory.createEmptyBorder(10,15,10,10));
        b.setFocusPainted(false);

        if(sel){
            b.setBackground(Theme.ACCENT);
            b.setForeground(Color.WHITE);
            selected=b;
        } else {
            b.setBackground(Theme.SIDEBAR);
            b.setForeground(Theme.TEXT_SECONDARY);
        }

        b.addActionListener(e->{layout.show(content,t);highlight(b);});
        return b;
    }

    private void highlight(JButton b){
        selected.setBackground(Theme.SIDEBAR);
        selected.setForeground(Theme.TEXT_SECONDARY);
        b.setBackground(Theme.ACCENT);
        b.setForeground(Color.WHITE);
        selected=b;
    }

    private JPanel collection(String n,int c){
        JPanel p=new JPanel(new BorderLayout());
        p.setBackground(Theme.SIDEBAR);
        p.setBorder(BorderFactory.createEmptyBorder(8,20,8,10));

        JLabel l=new JLabel(n);
        l.setForeground(Color.WHITE);

        JLabel badge=new JLabel(""+c);
        badge.setOpaque(true);
        badge.setBackground(Theme.ACCENT);
        badge.setForeground(Color.WHITE);
        badge.setBorder(BorderFactory.createEmptyBorder(2,6,2,6));

        p.add(l,BorderLayout.WEST);
        p.add(badge,BorderLayout.EAST);
        return p;
    }

    private JPanel profile(){
        JPanel p=new JPanel(new GridLayout(3,1));
        p.setBackground(new Color(35,37,42));
        p.setBorder(BorderFactory.createEmptyBorder(10,10,10,10));

        p.add(new JLabel("Rugved Deshpande"));
        p.add(new JLabel("Full Stack Developer"));
        p.add(new JLabel("● Online"));

        return p;
    }

    private JPanel main(){
        content.add(new SnippetPanel(),"Snippets");
        content.add(new JLabel("Coming Soon"),"API Tester");
        content.add(new JLabel("Coming Soon"),"JSON Formatter");
        return content;
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new MainFrame().setVisible(true));
    }
}


