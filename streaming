🧠 Step 6: Service Layer (Clean Abstraction)

📄 service/SnippetService.java

package com.devworkbench.service;

import com.devworkbench.dao.SnippetDAO;
import com.devworkbench.model.Snippet;

import java.util.List;

public class SnippetService {

    private final SnippetDAO dao = new SnippetDAO();

    public void addSnippet(String title, String code) {
        dao.save(new Snippet(title, code));
    }

    public List<Snippet> getAllSnippets() {
        return dao.findAll();
    }

    public void deleteSnippet(int id) {
        dao.delete(id);
    }
}


