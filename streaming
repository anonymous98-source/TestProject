package com.cardinalhealth.advship.preferences.api.controller;

import com.cardinalhealth.advship.preferences.api.dto.response.FedexSubscriptionResponse;
import com.cardinalhealth.advship.preferences.api.service.FedexSubscriptionService;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.test.web.servlet.MockMvc;

import java.util.UUID;

import static org.mockito.Mockito.when;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

@WebMvcTest(FedexSubscriptionController.class)
class FedexSubscriptionControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockBean
    private FedexSubscriptionService service;

    @Test
    void shouldReturnSubscriptionDetails() throws Exception {

        UUID customerId = UUID.randomUUID();

        UUID registrationId = UUID.randomUUID();
        UUID subscriptionId = UUID.randomUUID();

        String accountNumber = "123456";

        when(service.getFedexSubscription(
                customerId,
                accountNumber))
                .thenReturn(
                        new FedexSubscriptionResponse(
                                registrationId,
                                subscriptionId,
                                accountNumber));

        mockMvc.perform(
                        get("/v1/api/fedex/subscription")
                                .param(
                                        "customerId",
                                        customerId.toString())
                                .param(
                                        "accountNumber",
                                        accountNumber))
                .andExpect(status().isOk())
                .andExpect(
                        jsonPath("$.registrationId")
                                .value(
                                        registrationId.toString()))
                .andExpect(
                        jsonPath("$.subscriptionId")
                                .value(
                                        subscriptionId.toString()))
                .andExpect(
                        jsonPath("$.accountNumber")
                                .value(accountNumber));
    }

    @Test
    void shouldReturnEmptyResponseWhenSubscriptionNotFound()
            throws Exception {

        UUID customerId = UUID.randomUUID();

        when(service.getFedexSubscription(
                customerId,
                "123456"))
                .thenReturn(null);

        mockMvc.perform(
                        get("/v1/api/fedex/subscription")
                                .param(
                                        "customerId",
                                        customerId.toString())
                                .param(
                                        "accountNumber",
                                        "123456"))
                .andExpect(status().isOk());
    }
}

