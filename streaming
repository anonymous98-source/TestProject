🧩 Menu Item (Clickable Like IDE)

private JButton createMenuItem(String text) {
    JButton btn = new JButton("  " + text);
    btn.setHorizontalAlignment(SwingConstants.LEFT);
    btn.setFocusPainted(false);
    btn.setForeground(Color.WHITE);
    btn.setBackground(new Color(28, 30, 34));
    btn.setFont(new Font("Segoe UI", Font.PLAIN, 13));
    btn.setBorder(BorderFactory.createEmptyBorder(10, 15, 10, 10));
    btn.setCursor(new Cursor(Cursor.HAND_CURSOR));

    btn.addActionListener(e -> switchPanel(text));

    // Hover effect
    btn.addMouseListener(new java.awt.event.MouseAdapter() {
        public void mouseEntered(java.awt.event.MouseEvent evt) {
            btn.setBackground(new Color(45, 48, 54));
        }

        public void mouseExited(java.awt.event.MouseEvent evt) {
            btn.setBackground(new Color(28, 30, 34));
        }
    });

    return btn;
}


