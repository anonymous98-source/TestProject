Yes. Since your service logic has changed, your FedexSubscriptionServiceImplTest should now cover all four scenarios.

Assuming you're using JUnit 5 + Mockito (same pattern as your existing project), here's the test class.

@ExtendWith(MockitoExtension.class)
class FedexSubscriptionServiceImplTest {

    @Mock
    private FedexSubscriptionRepository fedexSubscriptionRepository;

    @InjectMocks
    private FedexSubscriptionServiceImpl service;

    private static final String CUSTOMER_ID = "CUST001";
    private static final String REGISTRATION_ID = "REG001";
    private static final String SUBSCRIPTION_ID = "SUB001";
    private static final String ACCOUNT_NUMBER = "ACC001";

    private FedexSubscriptionEntity entity;

    @BeforeEach
    void setUp() {
        entity = new FedexSubscriptionEntity();
        entity.setCustomerId(CUSTOMER_ID);
        entity.setRegistrationId(REGISTRATION_ID);
        entity.setSubscriptionId(SUBSCRIPTION_ID);
    }

    @Test
    @DisplayName("Customer not found")
    void shouldReturnNullWhenCustomerNotFound() {

        when(fedexSubscriptionRepository.findByCustomerId(CUSTOMER_ID))
                .thenReturn(Collections.emptyList());

        FedexSubscriptionFetchResponse response =
                service.getFedexSubscription(CUSTOMER_ID, ACCOUNT_NUMBER);

        assertNull(response);

        verify(fedexSubscriptionRepository)
                .findByCustomerId(CUSTOMER_ID);
    }

    @Test
    @DisplayName("Customer exists and account exists")
    void shouldReturnAllFieldsWhenAccountExists() {

        when(fedexSubscriptionRepository.findByCustomerId(CUSTOMER_ID))
                .thenReturn(List.of(entity));

        when(fedexSubscriptionRepository.countAccountsBySubscriptionId(SUBSCRIPTION_ID))
                .thenReturn(100L);

        when(fedexSubscriptionRepository.findAccountNumber(
                SUBSCRIPTION_ID,
                ACCOUNT_NUMBER))
                .thenReturn(Optional.of(ACCOUNT_NUMBER));

        FedexSubscriptionFetchResponse response =
                service.getFedexSubscription(CUSTOMER_ID, ACCOUNT_NUMBER);

        assertNotNull(response);
        assertEquals(REGISTRATION_ID, response.getRegistrationId());
        assertEquals(SUBSCRIPTION_ID, response.getSubscriptionId());
        assertEquals(ACCOUNT_NUMBER, response.getAccountNumber());
    }

    @Test
    @DisplayName("Customer exists but account not found")
    void shouldReturnNullAccountNumberWhenAccountMissing() {

        when(fedexSubscriptionRepository.findByCustomerId(CUSTOMER_ID))
                .thenReturn(List.of(entity));

        when(fedexSubscriptionRepository.countAccountsBySubscriptionId(SUBSCRIPTION_ID))
                .thenReturn(10L);

        when(fedexSubscriptionRepository.findAccountNumber(
                SUBSCRIPTION_ID,
                ACCOUNT_NUMBER))
                .thenReturn(Optional.empty());

        FedexSubscriptionFetchResponse response =
                service.getFedexSubscription(CUSTOMER_ID, ACCOUNT_NUMBER);

        assertNotNull(response);
        assertEquals(REGISTRATION_ID, response.getRegistrationId());
        assertEquals(SUBSCRIPTION_ID, response.getSubscriptionId());
        assertNull(response.getAccountNumber());
    }

    @Test
    @DisplayName("Subscription has more than 500 accounts")
    void shouldReturnNullSubscriptionIdWhenAccountLimitExceeded() {

        when(fedexSubscriptionRepository.findByCustomerId(CUSTOMER_ID))
                .thenReturn(List.of(entity));

        when(fedexSubscriptionRepository.countAccountsBySubscriptionId(SUBSCRIPTION_ID))
                .thenReturn(501L);

        FedexSubscriptionFetchResponse response =
                service.getFedexSubscription(CUSTOMER_ID, ACCOUNT_NUMBER);

        assertNotNull(response);
        assertEquals(REGISTRATION_ID, response.getRegistrationId());
        assertNull(response.getSubscriptionId());
        assertEquals(ACCOUNT_NUMBER, response.getAccountNumber());

        verify(fedexSubscriptionRepository, never())
                .findAccountNumber(anyString(), anyString());
    }
}

